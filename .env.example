# =============================================================================
# Lembo hackathon Agaton — copia in ".env" e compila i valori reali.
# Non committare mai .env (è in .gitignore).
# =============================================================================
#
# Documentazione rapida:
#   Supabase API:     https://supabase.com/docs/guides/api
#   Supabase Mgmt:   https://supabase.com/docs/reference/api
#   OpenAI API:       https://platform.openai.com/docs/api-reference
#   OpenAI chat/testo: https://platform.openai.com/docs/guides/text-generation
#                       https://platform.openai.com/docs/guides/chat
#   Gemini:           https://ai.google.dev/gemini-api/docs
#   Claude:           https://docs.anthropic.com/en/api/getting-started
#   Modelli Claude:   https://docs.anthropic.com/en/docs/about-claude/models
#
# =============================================================================

# --- Supabase (Dashboard → Project Settings → API) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
# Opzionale: bypass RLS — solo se regole hackathon/sicurezza lo consentono; non esporre al frontend.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- OpenAI (stessa API key per API / uso tipo ChatGPT) ---
OPENAI_API_KEY=sk-your-key
# ID modello aggiornabile senza toccare il codice
OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini (Google AI Studio: tipicamente GOOGLE_API_KEY) ---
GOOGLE_API_KEY=your-google-ai-key
# Alternativa se preferisci un solo nome "gemini" in env:
# GEMINI_API_KEY=your-google-ai-key
GEMINI_MODEL=gemini-2.0-flash

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
